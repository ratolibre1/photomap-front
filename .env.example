# API Keys
VITE_MAPTILER_API_KEY=your_maptiler_api_key_here

# Backend API URL - será usada en producción
# No incluir en desarrollo (usará localhost por defecto)
VITE_API_URL=https://tu-backend-url.com

# Este archivo sirve como plantilla para configurar tu archivo .env
# Copia este archivo como .env y agrega tus propias claves API
# No añadas nunca el archivo .env real al control de versiones 